VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 应用构建只产出 dist，发布归档由部署流水线负责。
VITE_ARCHIVER=false

# 后台接口签名、验签、加密、解密配置请参考 `.env.security.example`。
# 生产环境必须由 CI/CD 或部署平台注入完整安全变量，缺失时构建会直接失败。
