# 后台接口安全链路配置样例。
# 复制本文件内容到 `.env.development.local` 或 CI/CD 环境变量中使用，不建议把真实密钥提交到仓库。

# 当前前端接入的 AppID，需要与后端 `app_id` 或秘钥管理中的 `uuid` 一致。
VITE_ADMIN_SECURITY_APP_ID=203

# 是否启用请求签名和响应验签；生产建议开启。
VITE_ADMIN_SIGNATURE_ENABLED=true

# 是否启用请求加密和响应解密；生产建议开启。
VITE_ADMIN_CRYPTO_ENABLED=true

# 请求签名算法：R=RSA，A=AES，M=MD5；生产建议使用 R。
VITE_ADMIN_SIGNATURE_TYPE=R

# 请求加密算法：当前浏览器端只支持 A=AES。
VITE_ADMIN_CRYPTO_TYPE=A

# AES-CBC KEY，长度必须为 16/24/32 位；需要与后端当前 AppID 的 AES KEY 保持一致。
VITE_ADMIN_SECURITY_AES_KEY=replace-with-16-24-or-32-byte-aes-key

# AES-CBC IV，长度必须为 16 位；需要与后端当前 AppID 的 AES IV 保持一致。
VITE_ADMIN_SECURITY_AES_IV=replace-with-16-byte-iv

# 前端请求签名私钥，必须与后端配置的“用户 RSA 公钥”成对。
# PEM 需要写成单行，换行使用 \n；示例值只保留占位，避免被密钥扫描误判。
VITE_ADMIN_SIGNATURE_PRIVATE_KEY=replace-with-client-rsa-private-key-pem-escaped

# 后端响应验签公钥，必须与后端配置的“服务端 RSA 私钥”成对。
# PEM 需要写成单行，换行使用 \n；示例值只保留占位，避免提交真实公钥。
VITE_ADMIN_SIGNATURE_PUBLIC_KEY=replace-with-server-rsa-public-key-pem-escaped
